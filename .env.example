# =============================================================================
# ConvoInsight Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
#
# This file lives at the repo root so that both docker-compose and Django
# (via python-decouple, which walks up from backend/) can find it.
# =============================================================================

# Open a Python shell
# python backend/manage.py shell

# >> from django.core.management.utils import get_random_secret_key
# >> get_random_secret_key()

# --- Django ---
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-!@#$%^&*()
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_DEBUG=True
DJANGO_PAGINATION_LIMIT=18

# --- Database (PostgreSQL) ---
DB_NAME=convoinsight
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5433

# --- Redis ---
REDIS_URL=redis://localhost:6380/0

# --- AI Services ---
OPENAI_API_KEY=sk-your-openai-api-key-here
HUGGINGFACEHUB_API_TOKEN=hf_your-huggingface-token-here
TAVILY_API_KEY=tvly-your-tavily-key-here

# --- Optional: AWS S3 (Production Only) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# REGION_NAME=
